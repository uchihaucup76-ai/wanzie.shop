# Supabase — ambil dari Project Settings > API di dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RumahOTP — ambil dari halaman profile > developer di rumahotp.io
RUMAHOTP_API_KEY=your-rumahotp-api-key
RUMAHOTP_BASE_URL=https://www.rumahotp.io/api

# Markup harga jual ke user, dalam persen. Contoh 20 = harga modal + 20%
NEXT_PUBLIC_MARKUP_PERCENT=20
